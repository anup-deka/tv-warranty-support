# DigitalOcean Inference
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
DO_INFERENCE_API_KEY=your_do_inference_api_key_here
DO_LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
DO_EMBEDDING_MODEL=text-embedding-ada-002

# PostgreSQL (DO Managed Database)
DATABASE_URL=postgresql://user:password@host:25060/warranty_db?sslmode=require

# DigitalOcean Spaces
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=tv-warranty-policies
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_POLICY_FILE=warranty_policy.txt
